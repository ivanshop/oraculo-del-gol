@page "/"
@inject IJSRuntime JS

@using Oraculo.Web.Services
@using Oraculo.Web.Components
@using Oraculo.Web.Helpers

@inject OraculoService OraculoApi
@inject TelegramHelper Telegram

<div class="container">
    <div class="card rounded-5">
        <h3 class="text-center">📝 Partidos del día</h3>
        @if (_isLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando partidos...</span>
                </div>
                <p class="mt-2">Cargando partidos...</p>
            </div>
        }
        else if (!_matches.Any())
        {
            <p class="text-center py-3">No hay partidos programados para hoy</p>
        }
        else
        {
            @foreach (var match in _matches)
            {
                <MatchComponent Match="match" OnScoreSaved="OnMatchSaved" />
            }
        }
    </div>

    @* 
    <div class="card">
        <h3>🎮 Controles nativos de Telegram</h3>
        <button class="btn btn-primary" @onclick="MostrarAlerta">Mostrar Alerta Nativa</button>
        <button class="btn btn-warning" @onclick="MostrarConfirmacion">Mostrar Confirmación</button>
        <button class="btn btn-success" @onclick="Vibrar">Haptic Feedback</button>
        <button class="btn btn-info" @onclick="MostrarMainButton">Mostrar Botón Principal</button>
        <button class="btn btn-secondary" @onclick="OcultarMainButton">Ocultar Botón Principal</button>
    </div> *@


    @if (!string.IsNullOrEmpty(_resultado))
    {
        <div class="card resultado">
            <h3>✅ Resultado</h3>
            <p>@_resultado</p>
        </div>
    }
</div>

        
@code {
    private string _nombre = "Usuario";
    private bool _esTelegram;
    private string _inputNombre = "";
    private string _servicio = "";
    private string _prioridad = "";
    private string _descripcion = "";
    private string _resultado = "";
    private bool _isLoading = true;

    private List<Models.MatchPredictionModel> _matches = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            string today = DateTime.Now.ToString("yyyy-MM-dd");
            var matches = await OraculoApi.GetMatchesToday(today);
            if (matches.Any())
            {
                _matches = matches.Select(m => new Models.MatchPredictionModel
                {
                    Id = m.Id,
                    Scheduling = m.MatchTime,
                    IsDone = m.IsDone,
                    Home = new Models.TeamModel { Id = m.HomeId, Name = m.Home, Flag = m.HomeFlag, Goals = m.HomeGoals },
                    Away = new Models.TeamModel { Id = m.AwayId, Name = m.Away, Flag = m.AwayFlag, Goals = m.AwayGoals },
                    Prediction = new Models.PredictionModel()
                }).ToList();
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _esTelegram = await Telegram.IsAvailableAsync();

        if (_esTelegram)
        {
            await Telegram.ReadyAsync();

            var user = await Telegram.GetUserAsync();
            if (user is not null)
                _nombre = string.IsNullOrEmpty(user.FirstName) ? "Usuario" : user.FirstName;

            Telegram.OnMainButtonClicked += async () =>
            {
                // await EnviarFormulario();
                await InvokeAsync(StateHasChanged);
            };
        }

        StateHasChanged();
    }

    
    private async Task OnMatchSaved(Models.MatchPredictionModel match)
    {
        Console.WriteLine($"Guardado: {match.Home} {match.Home.Goals} - {match.Away.Goals} {match.Away}");

