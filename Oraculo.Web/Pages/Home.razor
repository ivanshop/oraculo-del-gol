@page "/"
@inject IJSRuntime JS

@using Oraculo.Web.Services
@using Oraculo.Web.Components
@using Oraculo.Web.Helpers

@inject OraculoService OraculoApi
@inject TelegramHelper Telegram

<div class="container">
    <div class="alert alert-warning text-wrap/break-all small">
        <strong>🔍 Debug Frontend:</strong><br />
        Es Telegram: @_isTelegram <br />
        Telegram ID: @(string.IsNullOrEmpty(_telegramUserId?.ToString()) ? "⚠️ VACÍO / NULL" : _telegramUserId) <br />
        Nombre: @_name
    </div>
    <div class="card rounded-5">
        <h3 class="text-center">📝 Partidos del día</h3>
        @if (_isLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando partidos...</span>
                </div>
                <p class="mt-2">Cargando partidos...</p>
            </div>
        }
        else if (!_matches.Any())
        {
            <p class="text-center py-3">No hay partidos programados para hoy.</p>
        }
        else
        {
            @foreach (var match in _matches)
            {
                <MatchComponent Match="match" OnScoreSaved="OnMatchSaved" />
            }
        }
    </div>
</div>

        
@code {
    private long? _telegramUserId;
    private string _name = "Usuario";
    private bool _isTelegram;
    private bool _isLoading = true;
    private string today = DateTime.Now.ToString("yyyy-MM-dd");
    private List<Models.MatchPredictionModel> _matches = new();
    private List<Models.UpdatedPredictionModel> _predictions = new();

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _isTelegram = await Telegram.IsAvailableAsync();

        if (_isTelegram)
        {
            await Telegram.ReadyAsync();
            await Task.Delay(250);

            var user = await Telegram.GetUserAsync();
            if (user is not null && user.Id != 0)
            {
                _telegramUserId = user.Id;
                _name = string.IsNullOrEmpty(user.FirstName) ? "Usuario" : user.FirstName;
                await GetCurrentMatchesByUserId(_telegramUserId.ToString()!, today);
            }
            else
            {
                _name = "Error al leer user de JS";
            }

            Telegram.OnMainButtonClicked += SendPredictionsAsync;
            await Telegram.ShowMainButtonAsync("ENVIAR PRONÓSTICO");
        }
        _isLoading = false;
        StateHasChanged();
    }

    private async Task GetCurrentMatchesByUserId(string telegramId, string date)
    {
        var matches = await OraculoApi.GetMatchesTodayAsync(telegramId, date);
        if (matches.Any())
        {
            _matches = matches.Select(m => new Models.MatchPredictionModel
            {
                Id = m.Id,
                UserId = telegramId,
                Scheduling = m.MatchTime,
                IsDone = m.IsDone,
                Home = new Models.TeamModel { Id = m.HomeId, Name = m.Home, Flag = m.HomeFlag, Goals = m.HomeGoals },
                Away = new Models.TeamModel { Id = m.AwayId, Name = m.Away, Flag = m.AwayFlag, Goals = m.AwayGoals },
                Prediction = new Models.PredictionModel { AwayGoals = m.AwayPrediction, HomeGoals = m.HomePrediction, Id = m.PredictionId, PredictedAt = m.PredictionDate }
            }).ToList();
        }
    }

    private async Task SendPredictionsAsync()
    {
        if (!_predictions.Any())
        {
            await Telegram.ShowAlertAsync("No has realizado ningún cambio en tus predicciones.");
            return;
        }
        await Telegram.HapticNotificationAsync("success");
        await OraculoApi.UpdatePredictionsAsync(_predictions);
        await Telegram.ShowAlertAsync($"¡Tu predicción ha sido enviada con éxito, {_name}!");
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnMatchSaved(Models.MatchPredictionModel match)
    {
        Models.UpdatedPredictionModel prediction = new
        (
            match.Prediction.Id,
            match.Id,
            match.UserId,
            match.Prediction.HomeGoals ?? 0,
            match.Prediction.AwayGoals ?? 0,
            DateTime.Now
        );
        var existingPrediction = _predictions.FirstOrDefault(p => p.Id == prediction.Id);
        if (existingPrediction is not null)
        {
            _predictions.Remove(existingPrediction);
        }
        if (prediction.CreatedAt <= match.Scheduling.AddMinutes(1))
        {
            _predictions.Add(prediction);
        }
    }

    public void Dispose()
    {
        if (_isTelegram)
        {
            Telegram.OnMainButtonClicked -= SendPredictionsAsync;
        }
    }
}
